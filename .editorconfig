# EditorConfig — consistent coding styles across editors
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cpp,h,hpp}]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
